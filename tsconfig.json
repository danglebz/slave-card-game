{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "types": ["vitest/globals"]
  },
  "include": ["server/**/*.js", "*.config.js", "test/**/*.js"],
  "exclude": ["node_modules", "dist", "tmp"]
}

{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "tailwind": {
      "command": "npx",
      "args": ["tailwindcss@latest", "mcp"]
    },
    "sentry": {
      "command": "npx",
      "args": ["sentry@latest", "mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}

{
  "name": "slave-card-game",
  "version": "1.20.0",
  "description": "เกมไพ่สลาฟออนไลน์ (President / Daifugo) เล่นพร้อมกัน 2–6 คนผ่านเบราว์เซอร์ — server-authoritative ด้วย Fastify + Socket.IO, ฝั่ง client React + TypeScript",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Danglebz <danglebz@hotmail.com>",
  "homepage": "https://slave-card-game.danglebz.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Danglebz/slave-card-game.git"
  },
  "bugs": {
    "url": "https://github.com/Danglebz/slave-card-game/issues"
  },
  "keywords": [
    "card-game",
    "slave",
    "president",
    "daifugo",
    "multiplayer",
    "realtime",
    "socket.io",
    "websocket",
    "fastify",
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "game"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.34.4",
  "main": "server/index.ts",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch --env-file-if-exists=.env server/index.ts",
    "build": "vite build && vite build --config vite.config.sw.ts",
    "build:release": "vite build && vite build --config vite.config.sw.ts && pnpm sentry:sourcemaps",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload --release $npm_package_version ./dist && find ./dist -name '*.map' -delete",
    "preview": "vite preview",
    "start": "tsx server/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.sw.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:smoke": "vitest run test/smoke",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "check:all": "pnpm check && pnpm test:e2e",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:dry": "commit-and-tag-version --dry-run",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli"
    ]
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-switch": "^1.3.1",
    "@sentry/browser": "^10.62.0",
    "@sentry/node": "^10.62.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.5",
    "lucide-react": "^1.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.1",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "valibot": "^1.4.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sentry/cli": "^3.6.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "prettier": "^3.8.5",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}

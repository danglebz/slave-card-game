# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (.env ถูก gitignore ไว้ — ห้าม commit ค่าจริง)

# ----- server -----
PORT=3000
# ไฟล์เซฟสถานะห้อง (เว้นว่าง = rooms.json ที่ root)
# ROOMS_FILE=rooms.json
# เวลาต่อตา (ms) และดีเลย์บอท (ms)
# TURN_MS=30000
# BOT_MS=600

# ----- logging / metrics -----
# ระดับ log: error | warn | info | debug
LOG_LEVEL=info
# ตั้งเพื่อกัน /metrics จากคนนอก (เว้นว่าง = เปิดอ่านได้)
# METRICS_TOKEN=

# ----- Sentry (error tracking) -----
# DSN ของโปรเจกต์ — เอามาจาก Sentry → Project Settings → Client Keys (DSN)
# ใช้ทั้ง server (runtime env) และ client (ฝังตอน build ผ่าน vite define)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# สำหรับ `pnpm build:release` (อัปโหลด source map เข้า Sentry ด้วย sentry-cli)
# auth token — ⚠️ ไม่ใช่ DSN; เก็บเป็นความลับ
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ----- Cookieless analytics (ฝังตอน build ผ่าน vite define) -----
# ไม่ใช้ cookie + ไม่เก็บ PII → ไม่ต้องทำ cookie consent banner
# ไม่ตั้ง ANALYTICS_SRC = ไม่โหลด analytics (โค้ดถูก tree-shake ทิ้ง)
#
# Plausible (cloud หรือ self-host):
# ANALYTICS_SRC=https://plausible.io/js/script.js
# ANALYTICS_DOMAIN=slave-card-game-5les.onrender.com
#
# Umami (self-host):
# ANALYTICS_SRC=https://analytics.example.com/script.js
# ANALYTICS_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

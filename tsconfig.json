{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": [
    "server/**/*.ts",
    "shared/**/*.ts",
    "client/src/**/*.{ts,tsx}",
    "test/**/*.{js,ts}",
    "*.config.{js,ts}"
  ],
  "exclude": ["node_modules", "dist", "tmp"]
}
